set exrc

set belloff=all

" set clipboard=unnamed,unnamedplus
syntax on

set nospell
set spelllang=en,de

set encoding=utf-8
set fileencoding=utf-8
set fileformat=unix
set nowritebackup
set nobackup
set noswapfile
set undofile

set noautochdir
set autoread
set noautowrite
set noautowriteall

set guicursor=
set background=dark
set signcolumn=yes
set termguicolors
set numberwidth=4
set number
set relativenumber
set cmdwinheight=10
set cmdheight=1

set scrolloff=1000
set sidescrolloff=20

set nowrap
set nolinebreak
set nobreakindent

set splitbelow
set splitright

set hlsearch
set ignorecase
set smartcase
set incsearch

set expandtab
set smartindent
set smarttab

set tabstop=4
set softtabstop=4
set shiftwidth=4

set noundofile

colorscheme industry
